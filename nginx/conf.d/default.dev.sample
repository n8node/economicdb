# Dev-only HTTP config (local docker compose).
# Production: generated into conf.d/default.conf from templates/default.http-redirect.conf

server {
    listen 80;
    server_name economicdb.com www.economicdb.com _;

    client_max_body_size 64M;
    resolver 127.0.0.11 valid=5s ipv6=off;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location = /api/v1/admin/ai/digest/regenerate {
        set $backend_upstream http://backend:8080;
        proxy_pass $backend_upstream;
        include /etc/nginx/includes/frontend-proxy-headers.conf;
        include /etc/nginx/includes/proxy-api-long.conf;
        include /etc/nginx/includes/cache-api.conf;
    }

    location /api/ {
        set $backend_upstream http://backend:8080;
        proxy_pass $backend_upstream;
        include /etc/nginx/includes/frontend-proxy-base.conf;
        include /etc/nginx/includes/cache-api.conf;
    }

    location = /health {
        set $backend_upstream http://backend:8080;
        proxy_pass $backend_upstream;
        proxy_set_header Host $host;
    }

    location = /deploy-id {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        include /etc/nginx/includes/frontend-proxy-headers.conf;
        include /etc/nginx/includes/cache-html.conf;
        proxy_connect_timeout 5s;
        proxy_read_timeout 10s;
        proxy_send_timeout 10s;
    }

    location /_next/static/ {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        include /etc/nginx/includes/frontend-proxy-base.conf;
        include /etc/nginx/includes/cache-static.conf;
    }

    location = /macro-hard-navigation.js {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        include /etc/nginx/includes/frontend-proxy-base.conf;
        include /etc/nginx/includes/cache-html.conf;
    }

    location /app {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        include /etc/nginx/includes/frontend-proxy-base.conf;
        include /etc/nginx/includes/cache-html.conf;
        proxy_intercept_errors on;
    }

    location /adminus {
        set $frontend_upstream http://frontend:3000;
        proxy_pass $frontend_upstream;
        include /etc/nginx/includes/frontend-proxy-base.conf;
        include /etc/nginx/includes/cache-html.conf;
        proxy_intercept_errors on;
    }

    location = /dbfiles {
        return 301 $scheme://$host/dbfiles/;
    }

    location /dbfiles/ {
        set $filebrowser_upstream http://filebrowser:80;
        proxy_pass $filebrowser_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 600s;
        proxy_redirect off;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        add_header X-Robots-Tag "noindex, nofollow" always;
    }

    location /wp-admin/ {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /wp-content/ {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /wp-includes/ {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /wp-json/ {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /wp-login.php {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://wordpress;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
