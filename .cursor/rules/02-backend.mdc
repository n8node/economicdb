## Загрузка секретов из БД

```python
# backend/app/services/settings_service.py
class SettingsService:
    async def get_secret(self, key: str) -> str:
        """openrouter.api_key, robokassa.password1, smtp.password, etc."""
        row = await self.repo.get_system_setting(key)
        return self.cipher.decrypt(row.value_encrypted)

    async def get_provider_config(self, provider_id: str) -> ProviderConfig:
        """enabled, base_url, api_key, rate_limit, last_sync_at"""
        row = await self.repo.get_data_provider(provider_id)
        creds = json.loads(self.cipher.decrypt(row.credentials_encrypted))
        return ProviderConfig(id=provider_id, **creds, enabled=row.enabled)
```

